# Docker Compose credentials — copy to .env.production
# REQUIRED: Set these before running docker compose up

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=czech_medai

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# API Keys (required)
ANTHROPIC_API_KEY=sk-ant-...

# Optional
LANGSMITH_API_KEY=
OPENAI_API_KEY=
