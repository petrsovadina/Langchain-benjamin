# ==================================================
# Czech MedAI - Environment Configuration Template
# ==================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ==================================================
# LLM API Keys (Required)
# ==================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here  # For guidelines embeddings (pgvector)

# ==================================================
# Model Configuration
# ==================================================
MODEL_NAME=claude-sonnet-4-5-20250929  # Used by all agents via constants.py

# ==================================================
# LangSmith Tracing (Optional but Recommended)
# ==================================================
# Get your API key from: https://smith.langchain.com/
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_TRACING=true

# ==================================================
# MCP Servers - SÚKL (Czech Pharmaceutical Database)
# ==================================================
SUKL_MCP_URL=https://SUKL-mcp.fastmcp.app/mcp
SUKL_MCP_TIMEOUT=30

# Local development (if running SÚKL-mcp locally)
# SUKL_MCP_URL=http://localhost:8000/mcp

# ==================================================
# MCP Servers - BioMCP (Biomedical Databases)
# ==================================================
BIOMCP_URL=http://localhost:8080
BIOMCP_TIMEOUT=60
BIOMCP_MAX_RESULTS=10

# ==================================================
# MCP Retry Logic
# ==================================================
MCP_MAX_RETRIES=3
MCP_RETRY_BASE_DELAY=1.0
MCP_RETRY_MAX_DELAY=30.0
MCP_RETRY_JITTER=true

# ==================================================
# Database (Supabase PostgreSQL + pgvector)
# ==================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/czech_medai
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_key_here

# ==================================================
# Redis Cache (Optional)
# ==================================================
REDIS_URL=redis://localhost:6379/0

# ==================================================
# FastAPI Server Configuration
# ==================================================
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ==================================================
# Security (NEVER commit real values!)
# ==================================================
# JWT_SECRET=your_random_secret_here
# RATE_LIMIT_PER_MINUTE=10

# ==================================================
# Notes:
# ==================================================
# 1. NEVER commit .env file to git (already in .gitignore)
# 2. Keep API keys secure - use environment variables in production
# 3. For local development, you can skip LangSmith (graceful degradation)
# 4. Translation uses ANTHROPIC_API_KEY (same as agents)
